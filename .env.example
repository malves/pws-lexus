# Port du serveur (defaut 8010)
PORT=8010

# --- Databowl : identifiants techniques d'integration (communs aux 2 pages) ---
# Fournis par la page "source-integration / HTTP" de Databowl. Valeurs par defaut : 628 / 2.
DATABOWL_CID=628
DATABOWL_SID=2

# --- Databowl : code campagne BACS par page (champ f_859_campaignid) ---
# C'est ce qui change entre PREPROD (local) et PROD (serveur), et par page.
# Sert de DEFAUT : surchargeable a chaud depuis l'admin (bouton "Databowl").
# Laisser vide = page non envoyee a Databowl (statut not_configured).
# Exemple preprod : DATABOWL_LBX_CAMPAIGN=701Aa00001RlRnv / DATABOWL_NX_CAMPAIGN=701Aa00001sbScR
DATABOWL_LBX_CAMPAIGN=
DATABOWL_NX_CAMPAIGN=
DATABOWL_CHR_CAMPAIGN=
DATABOWL_YARIS_CAMPAIGN=

# Ancienne variable (fallback global du code campagne si non defini par page).
DATABOWL_CAMPAIGN_ID=

# --- Back-office / dashboard admin ---
# Identifiants du compte admin unique (login du dashboard).
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Secret utilise pour signer le cookie de session admin.
# Mettre une longue chaine aleatoire en production (ex: openssl rand -hex 32).
SESSION_SECRET=remplace-moi-par-un-secret-aleatoire

# Chemin du fichier SQLite (defaut leads.db a la racine du projet)
DB_PATH=leads.db

# --- Google Analytics 4 (gtag.js) ---
# Defaut local : surchargeable depuis l'admin (bouton "Google Analytics").
# Priorite : valeur enregistree en base > variables ci-dessous.
# GA_MEASUREMENT_ID=G-S9MXH8G7T2
# GA_ENABLED=1
